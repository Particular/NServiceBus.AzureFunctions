<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\NServiceBus.snk</AssemblyOriginatorKeyFile>
    <Description>Azure Functions hosting for NServiceBus endpoints with Azure Serivce Bus triggers</Description>
    <!-- TEMPORARY: Silence XML documentation warnings on CI but leave active in local development -->
    <NoWarn Condition="'$(CI)' == 'true'">$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Functions.Worker.Extensions.ServiceBus" Version="5.24.0" />
    <PackageReference Include="NServiceBus.Transport.AzureServiceBus" Version="6.2.2" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Particular.Packaging" Version="4.5.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NServiceBus.AzureFunctions.Common\NServiceBus.AzureFunctions.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NServiceBus.AzureFunctions.Tests" Key="$(NServiceBusTestsKey)" />
  </ItemGroup>

</Project>
